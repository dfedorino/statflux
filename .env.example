# ---- Telegram ----
# Токен от @BotFather. Читает Java-код TelegramBotConfigFromEnv
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Юзернеймы без "@" через запятую (пример: soulol,dfedgg,grmkkmk).
TELEGRAM_BOT_WHITE_LIST=your_telegram_accounts

# ---- PostgreSQL init ----
# Читает postgres-контейнер при ПЕРВОМ запуске
# и создаёт внутри себя БД и пользователя с такими именами.
POSTGRES_DB=statflux_db
POSTGRES_USER=statflux
POSTGRES_PASSWORD=change_me_to_strong_password

# ---- PostgreSQL connection for Java ----
# Имя хоста `db` — имя сервиса в docker-compose.yml
# Имя БД в URL ДОЛЖНО совпадать с POSTGRES_DB выше.
DB_URL=jdbc:postgresql://db:5432/statflux_db
DB_USER=statflux
DB_PASSWORD=change_me_to_strong_password

# ---- Integrations tokens ----
YOUTUBE_API_KEY=your_youtube_api_key
VK_VIDEO_ACCESS_TOKEN=your_vk_access_token
RUTUBE_ACCESS_TOKEN=your_rutube_access_token

# ---- Refresh ----
REFRESH_INTERVAL_SECONDS=60
